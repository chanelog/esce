# Password untuk verifikasi admin
ADMIN_PASSWORD=peyx

# =============================================
# GITHUB CONFIGURATION
# =============================================

# Username GitHub
GITHUB_USER=PeyxDev

# Token GitHub (Personal Access Token)
GITHUB_TOKEN=[]

# Repository name
GITHUB_REPO=esce

# Email untuk Git config
GITHUB_EMAIL=peyxdev@gmail.com

# =============================================
# SCRIPT INSTALL CONFIGURATION
# =============================================

# Script install untuk Ubuntu
UBUNTU_INSTALL_SCRIPT=apt install -y screen dos2unix && wget -q https://raw.githubusercontent.com/PeyxDev/esce/main/setup.sh && chmod +x setup.sh && ./setup.sh

# Script install untuk Debian
DEBIAN_INSTALL_SCRIPT=apt update && apt install -y screen bsdextrautils util-linux coreutils wget curl dos2unix && wget -q https://raw.githubusercontent.com/PeyxDev/esce/main/setup.sh && chmod +x setup.sh && ./setup.sh

# =============================================
# USER MANAGEMENT CONFIGURATION
# =============================================

# Daftar user yang diizinkan (pisahkan dengan koma)
# Format: ALLOWED_USERS=id1,id2,id3
ALLOWED_USERS=7661292905

# =============================================
# SYSTEM CONFIGURATION
# =============================================

# Timezone untuk bot
BOT_TIMEZONE=Asia/Jakarta

# Log level (debug, info, error)
LOG_LEVEL=info

# Auto sync interval dalam menit (0 untuk disable)
AUTO_SYNC_INTERVAL=30