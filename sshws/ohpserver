#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <unistd.h>
#include <sys/types.h>
#include <sys/socket.h>
#include <netinet/in.h>
#include <arpa/inet.h>
#include <netdb.h>
#include <signal.h>
#include <time.h>
#include <errno.h>

#define BUFFER_SIZE 8192
#define MAX_CLIENTS 1000
#define VERSION "1.0.0"

typedef struct {
    int client_socket;
    int target_socket;
    int proxy_socket;
    struct sockaddr_in client_addr;
} client_data_t;

// Global variables
volatile sig_atomic_t stop_flag = 0;

// Signal handler for graceful shutdown
void handle_signal(int sig) {
    stop_flag = 1;
}

// Print usage information
void print_usage() {
    printf("OHP Server %s - Obfuscated HTTP Proxy\n", VERSION);
    printf("Usage: ohpserver -port <port> -proxy <proxy_ip:proxy_port> -tunnel <target_ip:target_port>\n");
    printf("Options:\n");
    printf("  -port <port>          Port to listen on\n");
    printf("  -proxy <ip:port>      Proxy server address\n");
    printf("  -tunnel <ip:port>     Target server address\n");
    printf("  -help                 Show this help message\n");
}

// Parse command line arguments
int parse_arguments(int argc, char *argv[], int *port, char **proxy_ip, int *proxy_port, char **tunnel_ip, int *tunnel_port) {
    for (int i = 1; i < argc; i++) {
        if (strcmp(argv[i], "-port") == 0) {
            if (i + 1 < argc) {
                *port = atoi(argv[++i]);
            } else {
                return -1;
            }
        } else if (strcmp(argv[i], "-proxy") == 0) {
            if (i + 1 < argc) {
                char *proxy_addr = argv[++i];
                char *colon = strchr(proxy_addr, ':');
                if (colon) {
                    *colon = '\0';
                    *proxy_ip = strdup(proxy_addr);
                    *proxy_port = atoi(colon + 1);
                } else {
                    return -1;
                }
            } else {
                return -1;
            }
        } else if (strcmp(argv[i], "-tunnel") == 0) {
            if (i + 1 < argc) {
                char *tunnel_addr = argv[++i];
                char *colon = strchr(tunnel_addr, ':');
                if (colon) {
                    *colon = '\0';
                    *tunnel_ip = strdup(tunnel_addr);
                    *tunnel_port = atoi(colon + 1);
                } else {
                    return -1;
                }
            } else {
                return -1;
            }
        } else if (strcmp(argv[i], "-help") == 0) {
            print_usage();
            exit(0);
        }
    }
    
    if (*port == 0 || *proxy_ip == NULL || *proxy_port == 0 || *tunnel_ip == NULL || *tunnel_port == 0) {
        return -1;
    }
    
    return 0;
}

// Create socket and bind to port
int create_server_socket(int port) {
    int server_socket;
    struct sockaddr_in server_addr;
    int opt = 1;
    
    // Create socket
    if ((server_socket = socket(AF_INET, SOCK_STREAM, 0)) == 0) {
        perror("Socket creation failed");
        return -1;
    }
    
    // Set socket options
    if (setsockopt(server_socket, SOL_SOCKET, SO_REUSEADDR, &opt, sizeof(opt))) {
        perror("Setsockopt failed");
        close(server_socket);
        return -1;
    }
    
    // Configure server address
    server_addr.sin_family = AF_INET;
    server_addr.sin_addr.s_addr = INADDR_ANY;
    server_addr.sin_port = htons(port);
    
    // Bind socket
    if (bind(server_socket, (struct sockaddr *)&server_addr, sizeof(server_addr)) < 0) {
        perror("Bind failed");
        close(server_socket);
        return -1;
    }
    
    // Listen for connections
    if (listen(server_socket, MAX_CLIENTS) < 0) {
        perror("Listen failed");
        close(server_socket);
        return -1;
    }
    
    printf("OHP Server listening on port %d\n", port);
    return server_socket;
}

// Connect to proxy server
int connect_to_proxy(const char *proxy_ip, int proxy_port) {
    int proxy_socket;
    struct sockaddr_in proxy_addr;
    
    // Create socket
    if ((proxy_socket = socket(AF_INET, SOCK_STREAM, 0)) < 0) {
        perror("Proxy socket creation failed");
        return -1;
    }
    
    // Configure proxy address
    proxy_addr.sin_family = AF_INET;
    proxy_addr.sin_port = htons(proxy_port);
    
    if (inet_pton(AF_INET, proxy_ip, &proxy_addr.sin_addr) <= 0) {
        perror("Invalid proxy address");
        close(proxy_socket);
        return -1;
    }
    
    // Connect to proxy
    if (connect(proxy_socket, (struct sockaddr *)&proxy_addr, sizeof(proxy_addr)) < 0) {
        perror("Proxy connection failed");
        close(proxy_socket);
        return -1;
    }
    
    printf("Connected to proxy %s:%d\n", proxy_ip, proxy_port);
    return proxy_socket;
}

// Connect to target server through proxy
int connect_to_target(int proxy_socket, const char *tunnel_ip, int tunnel_port) {
    char connect_request[BUFFER_SIZE];
    char response[BUFFER_SIZE];
    int bytes_received;
    
    // Send CONNECT request to proxy
    snprintf(connect_request, sizeof(connect_request),
             "CONNECT %s:%d HTTP/1.1\r\n"
             "Host: %s:%d\r\n"
             "Proxy-Connection: keep-alive\r\n"
             "User-Agent: OHP-Server/%s\r\n"
             "\r\n",
             tunnel_ip, tunnel_port, tunnel_ip, tunnel_port, VERSION);
    
    if (send(proxy_socket, connect_request, strlen(connect_request), 0) < 0) {
        perror("Failed to send CONNECT request");
        return -1;
    }
    
    // Read proxy response
    bytes_received = recv(proxy_socket, response, sizeof(response) - 1, 0);
    if (bytes_received <= 0) {
        perror("Failed to receive proxy response");
        return -1;
    }
    
    response[bytes_received] = '\0';
    
    // Check if CONNECT was successful (HTTP 200)
    if (strstr(response, "200") == NULL) {
        printf("Proxy rejected CONNECT request:\n%s\n", response);
        return -1;
    }
    
    printf("Tunnel established to %s:%d via proxy\n", tunnel_ip, tunnel_port);
    return 0;
}

// Forward data between two sockets
void forward_data(int from_socket, int to_socket) {
    char buffer[BUFFER_SIZE];
    int bytes_read;
    
    bytes_read = recv(from_socket, buffer, sizeof(buffer), 0);
    if (bytes_read > 0) {
        send(to_socket, buffer, bytes_read, 0);
    }
}

// Handle client connection
void handle_client(int client_socket, const char *proxy_ip, int proxy_port, const char *tunnel_ip, int tunnel_port) {
    int proxy_socket;
    struct sockaddr_in client_addr;
    socklen_t addr_len = sizeof(client_addr);
    fd_set read_fds;
    int max_fd;
    
    // Get client address
    getpeername(client_socket, (struct sockaddr *)&client_addr, &addr_len);
    printf("New client connection from %s:%d\n", 
           inet_ntoa(client_addr.sin_addr), ntohs(client_addr.sin_port));
    
    // Connect to proxy
    proxy_socket = connect_to_proxy(proxy_ip, proxy_port);
    if (proxy_socket < 0) {
        close(client_socket);
        return;
    }
    
    // Establish tunnel to target
    if (connect_to_target(proxy_socket, tunnel_ip, tunnel_port) < 0) {
        close(client_socket);
        close(proxy_socket);
        return;
    }
    
    // Data forwarding loop
    while (!stop_flag) {
        FD_ZERO(&read_fds);
        FD_SET(client_socket, &read_fds);
        FD_SET(proxy_socket, &read_fds);
        
        max_fd = (client_socket > proxy_socket) ? client_socket : proxy_socket;
        
        struct timeval timeout = {1, 0}; // 1 second timeout
        int activity = select(max_fd + 1, &read_fds, NULL, NULL, &timeout);
        
        if (activity < 0 && errno != EINTR) {
            perror("Select error");
            break;
        }
        
        if (activity > 0) {
            if (FD_ISSET(client_socket, &read_fds)) {
                forward_data(client_socket, proxy_socket);
            }
            
            if (FD_ISSET(proxy_socket, &read_fds)) {
                forward_data(proxy_socket, client_socket);
            }
        }
        
        // Check if connections are still alive
        char test_buffer[1];
        if (recv(client_socket, test_buffer, sizeof(test_buffer), MSG_PEEK | MSG_DONTWAIT) == 0) {
            break; // Client disconnected
        }
        
        if (recv(proxy_socket, test_buffer, sizeof(test_buffer), MSG_PEEK | MSG_DONTWAIT) == 0) {
            break; // Proxy disconnected
        }
    }
    
    printf("Client %s:%d disconnected\n", 
           inet_ntoa(client_addr.sin_addr), ntohs(client_addr.sin_port));
    
    close(client_socket);
    close(proxy_socket);
}

int main(int argc, char *argv[]) {
    int server_port = 0;
    char *proxy_ip = NULL;
    int proxy_port = 0;
    char *tunnel_ip = NULL;
    int tunnel_port = 0;
    int server_socket, client_socket;
    struct sockaddr_in client_addr;
    socklen_t addr_len = sizeof(client_addr);
    
    // Parse command line arguments
    if (parse_arguments(argc, argv, &server_port, &proxy_ip, &proxy_port, &tunnel_ip, &tunnel_port) < 0) {
        fprintf(stderr, "Invalid arguments\n");
        print_usage();
        return 1;
    }
    
    printf("OHP Server %s Starting...\n", VERSION);
    printf("Configuration:\n");
    printf("  Listen Port: %d\n", server_port);
    printf("  Proxy Server: %s:%d\n", proxy_ip, proxy_port);
    printf("  Tunnel Target: %s:%d\n", tunnel_ip, tunnel_port);
    
    // Setup signal handlers
    signal(SIGINT, handle_signal);
    signal(SIGTERM, handle_signal);
    
    // Create server socket
    server_socket = create_server_socket(server_port);
    if (server_socket < 0) {
        fprintf(stderr, "Failed to create server socket\n");
        free(proxy_ip);
        free(tunnel_ip);
        return 1;
    }
    
    // Main server loop
    while (!stop_flag) {
        // Accept client connections with timeout
        fd_set read_fds;
        FD_ZERO(&read_fds);
        FD_SET(server_socket, &read_fds);
        
        struct timeval timeout = {1, 0}; // 1 second timeout
        int activity = select(server_socket + 1, &read_fds, NULL, NULL, &timeout);
        
        if (activity < 0 && errno != EINTR) {
            perror("Select error");
            break;
        }
        
        if (activity > 0 && FD_ISSET(server_socket, &read_fds)) {
            client_socket = accept(server_socket, (struct sockaddr *)&client_addr, &addr_len);
            if (client_socket < 0) {
                perror("Accept failed");
                continue;
            }
            
            // Handle client in separate process
            pid_t pid = fork();
            if (pid == 0) {
                // Child process
                close(server_socket);
                handle_client(client_socket, proxy_ip, proxy_port, tunnel_ip, tunnel_port);
                free(proxy_ip);
                free(tunnel_ip);
                exit(0);
            } else if (pid > 0) {
                // Parent process
                close(client_socket);
            } else {
                perror("Fork failed");
                close(client_socket);
            }
        }
    }
    
    // Cleanup
    printf("Shutting down OHP Server...\n");
    close(server_socket);
    free(proxy_ip);
    free(tunnel_ip);
    
    printf("OHP Server stopped\n");
    return 0;

}