#!/bin/bash
# WebSocket Proxy Server in Bash
# Created By PeyxDev

# Configuration
HOST="0.0.0.0"
PORT="${1:-80}"
LOG_FILE="/var/log/ws-server.log"
MAX_CLIENTS=1000

# WebSocket magic string
MAGIC_STRING="258EAFA5-E914-47DA-95CA-C5AB0DC85B11"

# Color codes for logging
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

# Logging function
log() {
    echo -e "$(date '+%Y-%m-%d %H:%M:%S') - $1" | tee -a "$LOG_FILE"
}

# Generate WebSocket accept key
generate_accept_key() {
    local key="$1"
    echo -n "${key}${MAGIC_STRING}" | sha1sum | xxd -r -p | base64
}

# Handle WebSocket frame
handle_websocket_frame() {
    local client_socket="$1"
    
    # Read first 2 bytes (header)
    read -r -n 2 header <&${client_socket}
    
    if [ ${#header} -lt 2 ]; then
        return 1
    fi
    
    # Extract opcode and payload length
    opcode=$(printf "%d" "'${header:0:1}")
    payload_len=$(printf "%d" "'${header:1:1}")
    
    # Mask bit is the highest bit of payload_len
    mask_bit=$((payload_len & 0x80))
    payload_len=$((payload_len & 0x7F))
    
    # Read extended length if needed
    if [ $payload_len -eq 126 ]; then
        read -r -n 2 extended_len <&${client_socket}
        payload_len=$((0x$(xxd -p <<< "$extended_len")))
    elif [ $payload_len -eq 127 ]; then
        read -r -n 8 extended_len <&${client_socket}
        payload_len=$((0x$(xxd -p <<< "$extended_len")))
    fi
    
    # Read masking key if present
    if [ $mask_bit -ne 0 ]; then
        read -r -n 4 masking_key <&${client_socket}
    fi
    
    # Read payload
    if [ $payload_len -gt 0 ]; then
        read -r -n $payload_len payload <&${client_socket}
    else
        payload=""
    fi
    
    # Unmask payload if masked
    if [ $mask_bit -ne 0 ] && [ $payload_len -gt 0 ]; then
        unmasked_payload=""
        for ((i=0; i<${#payload}; i++)); do
            char="${payload:$i:1}"
            mask_char="${masking_key:$((i % 4)):1}"
            unmasked_char=$(printf "\\x$(printf '%02x' $((0x$(printf '%02x' "'$char") ^ 0x$(printf '%02x' "'$mask_char"))))")
            unmasked_payload="${unmasked_payload}${unmasked_char}"
        done
        payload="$unmasked_payload"
    fi
    
    echo "$payload"
}

# Create WebSocket frame
create_websocket_frame() {
    local message="$1"
    local message_len=${#message}
    local frame=""
    
    # Frame type (0x81 for text frame)
    frame+="\x81"
    
    # Payload length
    if [ $message_len -lt 126 ]; then
        frame+=$(printf "\\x%02x" $message_len)
    elif [ $message_len -lt 65536 ]; then
        frame+="\x7e"
        frame+=$(printf "\\x%04x" $message_len | xxd -r -p)
    else
        frame+="\x7f"
        frame+=$(printf "\\x%016x" $message_len | xxd -r -p)
    fi
    
    # Payload
    frame+="$message"
    
    echo -n "$frame"
}

# Handle client connection
handle_client() {
    local client_socket="$1"
    local client_ip="$2"
    
    log "${GREEN}New connection from $client_ip${NC}"
    
    # Read HTTP request
    request=""
    while IFS= read -r -n 1 -t 2 char; do
        request+="$char"
        if [[ "$request" == *$'\r\n\r\n'* ]]; then
            break
        fi
    done <&${client_socket}
    
    if [[ -z "$request" ]]; then
        exec {client_socket}>&-
        return
    fi
    
    # Check if it's WebSocket upgrade request
    if echo "$request" | grep -q "Upgrade: websocket"; then
        # Extract WebSocket key
        ws_key=$(echo "$request" | grep -i "Sec-WebSocket-Key:" | cut -d':' -f2 | sed 's/^[ \t]*//' | tr -d '\r')
        
        if [[ -n "$ws_key" ]]; then
            # Generate accept key
            accept_key=$(generate_accept_key "$ws_key")
            
            # Send WebSocket handshake response
            response="HTTP/1.1 101 Switching Protocols\r\n"
            response+="Upgrade: websocket\r\n"
            response+="Connection: Upgrade\r\n"
            response+="Sec-WebSocket-Accept: $accept_key\r\n"
            response+="\r\n"
            
            echo -n "$response" >&${client_socket}
            
            log "${BLUE}WebSocket connection established with $client_ip${NC}"
            
            # Handle WebSocket communication
            while true; do
                # Read WebSocket frame
                message=$(handle_websocket_frame $client_socket)
                
                if [[ $? -ne 0 ]] || [[ -z "$message" ]]; then
                    break
                fi
                
                # Custom responses based on message content
                local response_message=""
                case "$message" in
                    "hello"|"hi")
                        response_message="👋 Hello there! Welcome to our WebSocket server!"
                        ;;
                    "time")
                        response_message="🕐 Current time: $(date '+%Y-%m-%d %H:%M:%S')"
                        ;;
                    "name")
                        response_message="🤖 I'm WebSocket Server v1.0 (Powered by Bash)"
                        ;;
                    "help")
                        response_message="📖 Available commands: hello, time, name, help, echo <message>"
                        ;;
                    "echo "*)
                        local echo_text="${message#echo }"
                        response_message="🔊 Echo: $echo_text"
                        ;;
                    *)
                        response_message="❓ Unknown command: '$message'. Type 'help' for available commands."
                        ;;
                esac
                
                # Send response
                if [[ -n "$response_message" ]]; then
                    response_frame=$(create_websocket_frame "$response_message")
                    echo -n "$response_frame" >&${client_socket}
                    log "Response sent to $client_ip: $response_message"
                fi
            done
        fi
    else
        # Regular HTTP request - Return HTML page instead of plain text
        response="HTTP/1.1 200 OK\r\n"
        response+="Content-Type: text/html; charset=utf-8\r\n"
        response+="Connection: close\r\n"
        response+="\r\n"
        response+="<!DOCTYPE html>
<html lang='en'>
<head>
    <meta charset='UTF-8'>
    <meta name='viewport' content='width=device-width, initial-scale=1.0'>
    <title>WebSocket Server</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { 
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; 
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #333;
        }
        .container {
            background: white;
            padding: 3rem;
            border-radius: 20px;
            box-shadow: 0 20px 40px rgba(0,0,0,0.1);
            text-align: center;
            max-width: 500px;
            width: 90%;
        }
        .logo {
            font-size: 3rem;
            margin-bottom: 1rem;
        }
        h1 {
            color: #4a5568;
            margin-bottom: 1rem;
            font-size: 2rem;
        }
        .status {
            background: #48bb78;
            color: white;
            padding: 0.5rem 1rem;
            border-radius: 50px;
            display: inline-block;
            margin: 1rem 0;
            font-weight: bold;
        }
        .info {
            background: #f7fafc;
            padding: 1.5rem;
            border-radius: 10px;
            margin: 1.5rem 0;
            border-left: 4px solid #667eea;
        }
        .server-info {
            text-align: left;
            margin-top: 1.5rem;
        }
        .server-info div {
            padding: 0.5rem 0;
            border-bottom: 1px solid #e2e8f0;
        }
        .footer {
            margin-top: 2rem;
            color: #718096;
            font-size: 0.9rem;
        }
    </style>
</head>
<body>
    <div class='container'>
        <div class='logo'>🌐</div>
        <h1>WebSocket Proxy Server</h1>
        <div class='status'>🟢 Server is Running</div>
        
        <div class='info'>
            <p><strong>This server is powered by Bash</strong> and can handle WebSocket connections for real-time communication.</p>
        </div>
        
        <div class='server-info'>
            <div><strong>📍 Host:</strong> $HOST</div>
            <div><strong>🔌 Port:</strong> $PORT</div>
            <div><strong>🚀 Status:</strong> Active and Listening</div>
            <div><strong>👥 Max Clients:</strong> $MAX_CLIENTS</div>
        </div>
        
        <div class='footer'>
            Created with ❤️ by PeyxDev | $(date '+%Y-%m-%d %H:%M:%S')
        </div>
    </div>
</body>
</html>"
        
        echo -e "$response" >&${client_socket}
    fi
    
    # Close connection
    exec {client_socket}>&-
    log "${YELLOW}Connection closed: $client_ip${NC}"
}

# Main server function
start_server() {
    log "${GREEN}Starting WebSocket Proxy Server on $HOST:$PORT${NC}"
    log "${BLUE}Powered By PeyxDev${NC}"
    
    # Create TCP socket
    if ! exec {server_fd}<>/dev/tcp/$HOST/$PORT; then
        log "${RED}Failed to start server on $HOST:$PORT${NC}"
        exit 1
    fi
    
    # Listen for connections
    while true; do
        # Accept connection
        if ! exec {client_fd}<>/dev/tcp/$HOST/$PORT; then
            continue
        fi
        
        # Get client IP
        client_ip=$(ss -o state established src $HOST:$PORT | grep -v Address | head -1 | awk '{print $5}' | cut -d':' -f1)
        
        # Handle client in background
        handle_client $client_fd $client_ip &
    done
}

# Show usage
usage() {
    echo "Usage: $0 [port]"
    echo "  port: Port to listen on (default: 80)"
    echo ""
    echo "Example:"
    echo "  $0 80"
    echo "  $0 2086"
}

# Main execution
main() {
    # Check if port is provided
    if [[ $# -gt 1 ]]; then
        usage
        exit 1
    fi
    
    # Validate port
    if [[ -n "$1" ]]; then
        if ! [[ "$1" =~ ^[0-9]+$ ]] || [[ "$1" -lt 1 ]] || [[ "$1" -gt 65535 ]]; then
            log "${RED}Invalid port number: $1${NC}"
            exit 1
        fi
        PORT="$1"
    fi
    
    # Check if port is privileged
    if [[ "$PORT" -lt 1024 ]] && [[ "$EUID" -ne 0 ]]; then
        log "${RED}Need root privileges for ports below 1024${NC}"
        exit 1
    fi
    
    # Start server
    start_server
}

# Run main function with all arguments
main "$@"